---

---

<footer class="flex-column">
  <img src="/img/logo-png.avif" alt="Logo" class="logo" />
  <h3>Tu Empresa</h3>

  <div class="contact-info flex-column">
    <p><i class="bi bi-telephone-fill"></i>+00 0000000000</p>
    <p><i class="bi bi-envelope-fill"></i>correo@tuempresa.com</p>
    <p><i class="bi bi-geo-alt-fill"></i>Tu Ciudad, País</p>
  </div>

  <div class="flex-row follow">
    <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
    <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
  </div>

  <code>©2025 Tu Empresa</code>
</footer>

<style>
  footer {
    background-color: var(--clr-dark);
    margin-top: auto;
    color: var(--clr-white);
    padding-bottom: 20px;
  }

  .logo {
    width: 80px;
    height: 80px;
    margin-top: -80px;
    border-radius: 10px;
    object-fit: contain;
  }

  h3 {
    color: var(--clr-white);
  }

  .contact-info {
    gap: 6px;
  }

  .contact-info p {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    color: var(--clr-white);
  }

  .follow {
    border: solid 1px rgba(255, 255, 255, 0.35);
    border-radius: 50px;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }

  .follow i {
    font-size: 26px;
    color: var(--clr-white);
    padding: 16px 22px;
    transition: var(--transition);
  }

  code {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.75rem;
  }

  @media (hover: hover) {
    .follow i:hover {
      background-color: var(--footer-hover-bg);
    }
  }
</style>
